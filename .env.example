# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase FCM
FCM_PROJECT_ID=your-firebase-project
FCM_PRIVATE_KEY=your-private-key
FCM_CLIENT_EMAIL=your-client-email

# Agent Config
AGENT_BOARDING_TIMEOUT_MINUTES=15
AGENT_GATE_TIMEOUT_MINUTES=30
AGENT_PRIVATE_CAR_TIMEOUT_MINUTES=90
AGENT_GPS_TIMEOUT_MINUTES=10